@using Microsoft.AspNetCore.Identity
@using WebExamen.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-lg-center">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <span class="nav-link text-white">
                Hola, @User.Identity?.Name
            </span>
        </li>
        <li class="nav-item">
            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                  method="post"
                  class="d-inline">
                <button type="submit" class="btn btn-outline-light btn-sm ms-lg-2">
                    Cerrar sesión
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="btn btn-outline-light btn-sm me-2" asp-area="Identity" asp-page="/Account/Login">
                Iniciar sesión
            </a>
        </li>
        <li class="nav-item">
            <a class="btn btn-light btn-sm" asp-area="Identity" asp-page="/Account/Register">
                Registrarse
            </a>
        </li>
    }
</ul>