@{
    ViewData["Title"] = "Inicio";
}

<div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
    <div class="container-fluid py-4">
        <h1 class="display-5 fw-bold">Sistema Web de Reservas de Hoteles</h1>
        <p class="col-md-10 fs-5">
            Plataforma desarrollada en ASP.NET Core MVC para la gestión de hoteles y reservas,
            con autenticación, control de roles y una interfaz responsiva.
        </p>
        <a asp-controller="Hoteles" asp-action="Index" class="btn btn-primary btn-lg">
            Ver hoteles disponibles
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Gestión de hoteles</h5>
                <p class="card-text">
                    El administrador puede registrar, editar, consultar y eliminar hoteles.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Reservas en línea</h5>
                <p class="card-text">
                    Los usuarios podrán consultar hoteles y realizar reservas de forma sencilla.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Panel administrativo</h5>
                <p class="card-text">
                    El sistema permitirá visualizar estadísticas y generar reportes en PDF.
                </p>
            </div>
        </div>
    </div>
</div>