@model IEnumerable<WebExamen.Models.Hotel>

@{
    ViewData["Title"] = "Hoteles";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Listado de hoteles</h2>
        <p class="text-muted mb-0">Consulta los hoteles registrados en el sistema.</p>
    </div>

    @if (User.IsInRole("Administrador"))
    {
        <a asp-action="Create" class="btn btn-primary">Registrar hotel</a>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-primary">
                    <tr>
                        <th>Nombre</th>
                        <th>Dirección</th>
                        <th>Precio por noche</th>
                        <th>Descripción</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nombre</td>
                            <td>@item.Direccion</td>
                            <td>Bs. @item.PrecioPorNoche</td>
                            <td>@item.Descripcion</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ver</a>

                                @if (User.IsInRole("Administrador"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>