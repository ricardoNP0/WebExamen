@model WebExamen.Models.Hotel

@{
    ViewData["Title"] = "Eliminar Hotel";
}

<div class="container mt-4">
    <h2>Eliminar Hotel</h2>
    <h4 class="text-danger">¿Estás seguro de eliminar este hotel?</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>

        <dt class="col-sm-3">Dirección</dt>
        <dd class="col-sm-9">@Model.Direccion</dd>

        <dt class="col-sm-3">Precio por noche</dt>
        <dd class="col-sm-9">Bs. @Model.PrecioPorNoche</dd>

        <dt class="col-sm-3">Descripción</dt>
        <dd class="col-sm-9">@Model.Descripcion</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>