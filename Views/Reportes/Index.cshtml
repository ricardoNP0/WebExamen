@model IEnumerable<WebExamen.ViewModels.ReporteReservaItemViewModel>

@{
    ViewData["Title"] = "Reportes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Reportes</h2>
        <p class="text-muted mb-0">Listado de reservas y exportación en PDF.</p>
    </div>
    <a asp-action="ReservasPdf" class="btn btn-danger">Descargar PDF</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Hotel</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Cliente</td>
                            <td>@item.Hotel</td>
                            <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>